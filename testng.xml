<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Suite" parallel="classes" thread-count="3">
	<listeners>
		<listener class-name="sdet_capstone.listeners.TestListener" />
	</listeners>
	<test name="Test">
		<parameter name="browserType" value="${browserType}" />
		<parameter name="isHeadless" value="${isHeadless}" />
		<classes>
			<class name="sdet_capstone.testcases.TC1" />
			<class name="sdet_capstone.testcases.TC2" />
			<class name="sdet_capstone.testcases.TC3" />
			<class name="sdet_capstone.testcases.TC4" />
			<class name="sdet_capstone.testcases.TC5" />
		</classes>
	</test>
</suite>
